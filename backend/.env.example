OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional OpenRouter API base (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: path to SQLite DB (default: <repo>/backend/database/all-cards.db)
# DATABASE_PATH=/path/to/all-cards.db

# Optional backend bind settings for mtg-card-search-backend only (default host 127.0.0.1; use 0.0.0.0 for all interfaces)
# BACKEND_HOST=127.0.0.1
# BACKEND_PORT=8000
